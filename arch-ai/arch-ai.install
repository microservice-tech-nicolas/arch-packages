_real_user() { echo "${SUDO_USER:-$(logname 2>/dev/null || whoami)}"; }
_real_home() { getent passwd "$(_real_user)" | cut -d: -f6; }

_install_or_update() {
  local name="$1" cmd="$2"
  echo "==> arch-ai: installing/updating ${name}..."
  if eval "${cmd}"; then
    echo "  [ok] ${name}"
  else
    echo "  [warn] ${name} failed — retry manually: ${cmd}"
  fi
}

post_install() {
  local user home
  user="$(_real_user)"
  home="$(_real_home)"

  # claude-code — official native installer (replaced npm install as of 2025)
  _install_or_update "claude-code" \
    "curl -fsSL https://claude.ai/install.sh | bash"

  # opencode — official install script
  _install_or_update "opencode" \
    "curl -fsSL https://opencode.ai/install | bash"

  # crush — charmbracelet's AI coding tool
  _install_or_update "crush" \
    "curl -fsSL https://charm.sh/install | bash -s -- crush"

  echo ""
  echo "==> arch-ai: done."
  echo "    claude  — run 'claude' to start Claude Code"
  echo "    opencode — run 'opencode' to start"
  echo "    crush    — run 'crush' to start"
  echo ""
  echo "    Set your API keys (never hardcode in .zshrc):"
  echo "      pass insert api/anthropic"
  echo "      pass insert api/openrouter"
}

post_upgrade() {
  post_install
}
