_real_user() { echo "${SUDO_USER:-$(logname 2>/dev/null || whoami)}"; }
_real_home() { getent passwd "$(_real_user)" | cut -d: -f6; }

_install_or_update() {
  local name="$1"
  local cmd="$2"
  echo "==> arch-ai: installing/updating ${name}..."
  if eval "${cmd}"; then
    echo "  [ok] ${name}"
  else
    echo "  [warn] ${name} failed — retry manually: ${cmd}"
  fi
}

post_install() {
  _install_or_update "claude-code" "npm install -g @anthropic-ai/claude-code --silent"

  # opencode — Go binary, install via their install script
  _install_or_update "opencode" \
    "curl -fsSL https://opencode.ai/install | bash"

  # crush — Go binary from charmbracelet
  _install_or_update "crush" \
    "curl -fsSL https://charm.sh/install | bash -s -- crush"

  echo "==> arch-ai: done."
  echo "    claude-code: run 'claude' to start"
  echo "    opencode:    run 'opencode' to start"
  echo "    crush:       run 'crush' to start"
}

post_upgrade() {
  post_install
}
