# Maintainer: Nicolas <nicolas.verhaert@microservice.tech>
pkgname=nic-nvim
pkgver=0.12.2
pkgrel=7
pkgdesc="Neovim — latest stable, built from source"
arch=('x86_64')
url="https://github.com/neovim/neovim"
license=('Apache-2.0' 'custom:Vim')
# Runtime deps: neovim binary + everything checkhealth requires
depends=(
  # neovim binary
  'gcc-libs' 'glibc'
  # LazyVim hard requirements
  'git' 'ripgrep' 'fd' 'fzf' 'lazygit' 'curl'
  # tree-sitter CLI (nvim-treesitter grammar compilation)
  'tree-sitter'
  # providers
  'python-pynvim'        # Python provider
  'nodejs' 'npm'         # Node.js provider (npm used in post_install to install neovim pkg)
  'perl' 'perl-app-cpanminus'  # Perl provider (cpanm used in post_install for Neovim::Ext)
  # clipboard & system open
  'wl-clipboard'         # Wayland clipboard (wl-copy)
  'xdg-utils'            # vim.ui.open via xdg-open
)
makedepends=('cmake' 'ninja' 'unzip' 'gettext')
install=nic-nvim.install
provides=('neovim')
conflicts=('neovim' 'neovim-git')
source=("neovim-${pkgver}.tar.gz::https://github.com/neovim/neovim/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "neovim-${pkgver}"
  # Use bundled deps so we don't need libluv/libvterm etc from repos
  cmake -S cmake.deps -B .deps \
    -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D USE_BUNDLED=ON
  cmake --build .deps

  cmake -B build \
    -G Ninja \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D ENABLE_TESTING=OFF \
    -D USE_BUNDLED=ON
  cmake --build build
}

package() {
  cd "neovim-${pkgver}"
  DESTDIR="${pkgdir}" cmake --install build
  install -Dm644 LICENSE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
